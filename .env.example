# Base de datos Neon Postgres (https://neon.tech)
# Usa la connection string "pooled" para la app.
DATABASE_URL="postgresql://usuario:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Vercel Blob (https://vercel.com/dashboard/stores) — almacenamiento de imagenes
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# Resend (https://resend.com) — envio de emails de notificacion
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Correo que recibe las notificaciones de nuevas cotizaciones
NOTIFY_EMAIL="demo@ejemplo.cl"
# Remitente verificado en Resend (o onboarding@resend.dev para pruebas)
RESEND_FROM="Vidrieria Demo <onboarding@resend.dev>"

# Auth.js v5 — generar con: npx auth secret
AUTH_SECRET="reemplazar-con-un-secreto-largo"

# Datos de contacto usados en el sitio
NEXT_PUBLIC_WHATSAPP="56900000000"
NEXT_PUBLIC_INSTAGRAM="https://instagram.com/vidrieria.demo"
